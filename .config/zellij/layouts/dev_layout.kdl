layout {
  default_tab_template {
    // top row: the tab-bar
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    // your actual tabs…
    children
    // bottom row: the status-bar
    pane size=2 borderless=true {
      plugin location="zellij:status-bar"
    }
  }

  tab name="sc-platform" focus=true {
    pane split_direction="vertical" {
        pane command="nvim" cwd="/Users/leonbergmann/development/sc-platform"

        pane split_direction="horizontal" {
            pane command="pnpm build:libs" cwd="/Users/leonbergmann/development/sc-platform"

            pane command="pnpm start:dev"cwd="/Users/leonbergmann/development/sc-platform/apps/storage-app"
        }
    }
  }

  tab name="old-project" cwd="/Users/leonbergmann/development/sweetconnect-platform" {
    pane split_direction="vertical" {
        pane
        pane command="task" args="serve"
    }
  }

  tab name="api docs" cwd="/Users/leonbergmann/development/sweetconnect-api" {
    pane
  }

  tab name="migrator" cwd="/Users/leonbergmann/development/sc-migrator" {
    pane split_direction="vertical" {
        pane
        pane
    }
  }

  tab name="fumadocs" cwd="/Users/leonbergmann/development/docs-test" {
    pane split_direction="vertical" {
        pane command="nvim"
        pane
    }
  }
}
